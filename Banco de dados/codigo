-- 1. Cria o banco de dados com o nome que está no seu .env
CREATE DATABASE IF NOT EXISTS alimconnect_db;
USE alimconnect_db;

-- 2. Cria a tabela de usuários (AlimConnect)
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL UNIQUE,
    senha VARCHAR(255) NOT NULL,
    role ENUM('admin', 'comprador', 'fornecedor') NOT NULL,
    description TEXT,
    img VARCHAR(255),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- 3. Cria a tabela de produtos vinculada ao fornecedor
CREATE TABLE products (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    price DECIMAL(10, 2) NOT NULL,
    category VARCHAR(50),
    stock INT DEFAULT 0,
    img VARCHAR(255),
    supplier_id INT,
    FOREIGN KEY (supplier_id) REFERENCES users(id) ON DELETE CASCADE
);